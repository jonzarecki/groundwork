{
  "permissions": {
    "allow": [
      "mcp__google-workspace__*",
      "mcp__slack__*",
      "mcp__google-contacts__*",
      "mcp__linkedin__*",
      "Bash(./scripts/*)",
      "Bash(sqlite3 *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [{ "type": "command", "command": ".claude/hooks/protect-files.sh" }]
      }
    ]
  }
}
