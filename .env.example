# Linked Collector Configuration
# Copy to .env and customize. The agent reads these before each run.

# Your email address -- used to filter out self from sightings.
LC_SELF_EMAIL=jzarecki@redhat.com

# Maximum number of recipients/attendees on an email or meeting before
# the sighting is skipped entirely. Large all-hands meetings and
# mailing-list blasts add noise without signal.
# Set to 0 to disable the limit.
LC_MAX_PARTICIPANTS=80
