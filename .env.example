# Groundwork Configuration
# Copy to .env and customize. The agent reads these before each run.

# Required: Your email address -- used to filter out self from sightings.
LC_SELF_EMAIL=you@example.com

# Data collection provider:
#   direct  (default) Google OAuth + Slack/LinkedIn Chrome cookie extraction.
#           No Docker, no MCP. Run: python3 scripts/setup-auth.py
#   mcp     Legacy: Docker + local-automation-mcp stack on localhost:9090.
LC_PROVIDER=direct

# Your Slack workspace subdomain (e.g., 'mycompany' for mycompany.slack.com).
# Required for the direct Slack provider.
LC_SLACK_WORKSPACE=mycompany

# Maximum number of recipients/attendees on an email or meeting before
# the sighting is skipped entirely. Large all-hands meetings and
# mailing-list blasts add noise without signal.
# Set to 0 to disable the limit.
LC_MAX_PARTICIPANTS=80

# Default collection window in days. "collect" uses this unless you
# specify a number (e.g., "collect 14" overrides to 14 days).
LC_COLLECT_DAYS=7

# Maximum contacts to enrich with LinkedIn per collect run.
LC_ENRICH_BATCH_SIZE=10

# MCP provider only: URL of the MCP proxy (default: http://localhost:9090).
# MCP_PROXY_URL=http://localhost:9090
